{
  "name": "@cobusgreyling/goal-cost",
  "version": "1.0.0",
  "description": "Estimate token spend for Grok Build /goal sessions by pattern and maturity. npx @cobusgreyling/goal-cost --pattern tests-green",
  "type": "module",
  "bin": {
    "goal-cost": "./dist/cli.js"
  },
  "files": [
    "dist",
    "registry.json",
    "README.md"
  ],
  "scripts": {
    "bundle": "node scripts/bundle-registry.mjs",
    "build": "npm run bundle && tsc",
    "test": "npm run build && node --test test/estimator.test.mjs",
    "prepublishOnly": "npm test",
    "start": "node dist/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "goal-engineering",
    "grok-build",
    "token-cost",
    "ai-agents"
  ],
  "author": "Cobus Greyling",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cobusgreyling/goal-engineering.git",
    "directory": "tools/goal-cost"
  },
  "homepage": "https://github.com/cobusgreyling/goal-engineering",
  "bugs": {
    "url": "https://github.com/cobusgreyling/goal-engineering/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^5.0.0",
    "yaml": "^2.8.2"
  }
}