{
  "name": "@cobusgreyling/goal-init",
  "version": "1.0.0",
  "description": "Scaffold goal engineering patterns and starters into any project. npx @cobusgreyling/goal-init . --pattern tests-green --tool grok",
  "type": "module",
  "bin": {
    "goal-init": "./dist/cli.js"
  },
  "files": [
    "dist",
    "starters",
    "templates",
    "patterns",
    "README.md"
  ],
  "scripts": {
    "bundle": "node scripts/bundle-assets.mjs",
    "build": "npm run bundle && tsc",
    "test": "npm run build && node --test test/cli.test.mjs",
    "prepublishOnly": "npm test",
    "start": "node dist/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "goal-engineering",
    "grok-build",
    "grok",
    "ai-agents",
    "coding-agents",
    "scaffold",
    "starter",
    "patterns"
  ],
  "author": "Cobus Greyling",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cobusgreyling/goal-engineering.git",
    "directory": "tools/goal-init"
  },
  "homepage": "https://github.com/cobusgreyling/goal-engineering",
  "bugs": {
    "url": "https://github.com/cobusgreyling/goal-engineering/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^5.0.0"
  }
}